#############################################
### SYSTEM DIRECTORIES ###
#############################################
[gid=0 uid=0 dperms=755 type=dir] /var/chroot/sshd
[gid=0 uid=0 dperms=700 type=dir] /var/ssh

#############################################
### SCRIPTS ###
#############################################
[perms=700] /etc/startup.sh = ${MAIN_BUILD_FILE_DIR}/startup.sh
[perms=700] /etc/network_setup.sh = ${MAIN_BUILD_FILE_DIR}/network_setup.sh
[perms=755] /etc/network_capture = ${MAIN_BUILD_FILE_DIR}/network_capture.sh

#############################################
### CONFIGURATION FILES ###
#############################################
[perms=0444] pci_server.cfg = ${MAIN_BUILD_FILE_DIR}/pci_server.cfg
[perms=0444] pci_hw.cfg = ${MAIN_BUILD_FILE_DIR}/pci_hw.cfg
[perms=0444] qcrypto.conf = ${MAIN_BUILD_FILE_DIR}/qcrypto.conf

/etc/hostname = ${MAIN_BUILD_FILE_DIR}/hostname
/etc/profile = ${MAIN_BUILD_FILE_DIR}/profile
/etc/passwd = ${MAIN_BUILD_FILE_DIR}/passwd
/etc/group = ${MAIN_BUILD_FILE_DIR}/group

#############################################
### SSH CONFIGURATION ###
#############################################
[perms=444] /var/ssh/sshd_config = ${MAIN_BUILD_FILE_DIR}/sshd_config
[uid=0 gid=0 perms=400] /var/ssh/ssh_host_rsa_key = ${MAIN_BUILD_FILE_DIR}/ssh_host_rsa_key
[uid=0 gid=0 perms=400] /var/ssh/ssh_host_rsa_key.pub = ${MAIN_BUILD_FILE_DIR}/ssh_host_rsa_key.pub

#############################################
### DATAROUTER ###
#############################################
[perms=777] /usr/bin/datarouter/datarouter = ${DATAROUTER}
[perms=644] /usr/bin/datarouter/etc/logging.json = ${MAIN_BUILD_FILE_DIR}/../../../../score/test/component/datarouter/etc/logging.json
[perms=644] /usr/bin/datarouter/etc/log-channels.json = ${MAIN_BUILD_FILE_DIR}/../../../../score/test/component/datarouter/etc/log-channels.json
[perms=644] /usr/bin/datarouter/etc/raw-channels.json = ${MAIN_BUILD_FILE_DIR}/../../../../score/test/component/datarouter/etc/raw-channels.json

#############################################
### PER-TEST FILESYSTEM ###
#############################################
[perms=777] / = ${FILESYSTEM}
